{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Standardberechtigungen: Fenster-Kernfunktionen sowie Datei-Dialoge für Export/Import.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "$APPDATA/**" }]
    }
  ]
}
